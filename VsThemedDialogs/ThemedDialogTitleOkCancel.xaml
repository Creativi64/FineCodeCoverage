<UserControl x:Name="_ThemedDialogTitleOkCancel"
  x:Class="VsThemedDialogs.ThemedDialogTitleOkCancel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:VsThemedDialogs"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <local:ThemedDialogTitleContent
    Title="{Binding Path=Title, ElementName=_ThemedDialogTitleOkCancel}"
    Margin="0,0,0,20">
    <DockPanel>
      <StackPanel
        DockPanel.Dock="Bottom"
        Margin="0,12,20,0"
        HorizontalAlignment="Right"
        Orientation="Horizontal">
        <Button
          Command="{Binding OkCommand}"
          Margin="6,0"
          Content="{Binding OkButtonText, RelativeSource={RelativeSource AncestorType=local:ThemedDialogTitleOkCancel}}" />
        <Button
          Command="{Binding CancelCommand}"
          IsDefault="True">
          Cancel
        </Button>
      </StackPanel>
      <ContentPresenter
        Margin="0,0,24,0"
        Content="{Binding Body, RelativeSource={RelativeSource AncestorType=local:ThemedDialogTitleOkCancel}}" />
    </DockPanel>
  </local:ThemedDialogTitleContent>
</UserControl>
