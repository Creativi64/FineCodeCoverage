<UserControl x:Class="VsThemedDialogs.ThemedDialogTitleOkCancel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VsThemedDialogs"
             x:Name="_ThemedDialogTitleOkCancel"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <local:ThemedDialogTitleContent Margin="0,0,0,20" Title="{Binding Path=Title, ElementName=_ThemedDialogTitleOkCancel}">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,20,0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="6,0" Command="{Binding OkCommand}" Content="{Binding OkButtonText, RelativeSource={RelativeSource AncestorType=local:ThemedDialogTitleOkCancel}}"/>
                <Button IsDefault="True" Command="{Binding CancelCommand}">Cancel</Button>
            </StackPanel>
            <ContentPresenter Margin="0,0,24,0" Content="{Binding Body, RelativeSource={RelativeSource AncestorType=local:ThemedDialogTitleOkCancel}}" />
        </DockPanel>
    </local:ThemedDialogTitleContent>
</UserControl>
