<UserControl x:Name="_ThemedDialogTitleContent"
  x:Class="VsThemedDialogs.ThemedDialogTitleContent"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:VsThemedDialogs"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <StackPanel
    Margin="24,0,0,0">
    <local:ThemedDialogWindowTitle
      Title="{Binding Title, ElementName=_ThemedDialogTitleContent}"
      Margin="0,0,24,0" />
    <ContentPresenter
      Margin="0,20,0,0"
      Content="{Binding Body, ElementName=_ThemedDialogTitleContent}" />
  </StackPanel>
</UserControl>
