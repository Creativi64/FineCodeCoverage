<UserControl x:Class="VsThemedDialogs.ThemedDialogTitleContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fccWpf="clr-namespace:VsThemedDialogs"
             x:Name="_ThemedDialogTitleContent"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
	<StackPanel Margin="24,0,0,0">
        <fccWpf:ThemedDialogWindowTitle Margin="0,0,24,0" Title="{Binding Title, ElementName=_ThemedDialogTitleContent}"/>
        <ContentPresenter Margin="0,20,0,0" Content="{Binding Body, ElementName=_ThemedDialogTitleContent}"/>
	</StackPanel>
</UserControl>
