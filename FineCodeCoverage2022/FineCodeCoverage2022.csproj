<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputType>Library</OutputType>
    <RootNamespace>FineCodeCoverage</RootNamespace>
    <AssemblyName>FineCodeCoverage2022</AssemblyName>
    <!-- Keep the VSIX output at bin\$(Configuration)\ (no TFM subfolder), matching the legacy project. -->
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- We keep the hand-written Properties\AssemblyInfo.cs. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>

    <!-- VSIX packaging.  VSSDKBuildToolsAutoSetup makes the Microsoft.VSSDK.BuildTools package import
         Microsoft.VsSDK.targets (which builds the .vsix) and apply the standard VSIX defaults
         (CreateVsixContainer, CopyLocalLockFileAssemblies, content inclusion).  Without it an SDK-style
         project compiles but never produces a .vsix. -->
    <VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>true</CopyOutputSymbolsToOutputDirectory>
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>

    <!-- Code style -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <RoslynatorVersion>4.13.1</RoslynatorVersion>
  </PropertyGroup>

  <!-- The WPF markup-compile pass builds a throwaway "*_wpftmp" project just to resolve XAML types.
       Running the IDE code-style analyzers there adds nothing and surfaces IDE0004 et al. as build
       errors, so disable analysis for it.  The real compile still enforces code style. -->
  <PropertyGroup Condition="$(MSBuildProjectName.EndsWith('_wpftmp'))">
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <RunAnalyzers>false</RunAnalyzers>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE;VS2022</DefineConstants>
    <DeployExtension>True</DeployExtension>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>

  <!-- Sources / VSCT that live outside the project cone and so are not auto-globbed. -->
  <ItemGroup>
    <Compile Include="..\Shared Files\FCCPackage.cs">
      <Link>FCCPackage.cs</Link>
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>FCCPackage.vsct</DependentUpon>
    </Compile>
    <VSCTCompile Include="..\Shared Files\FCCPackage.vsct">
      <Link>FCCPackage.vsct</Link>
      <Generator>VsctGenerator</Generator>
      <LastGenOutput>FCCPackage.cs</LastGenOutput>
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>

  <!-- Metadata for files the SDK already globs from the project folder. -->
  <ItemGroup>
    <Compile Update="source.extension.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>source.extension.vsixmanifest</DependentUpon>
    </Compile>
    <None Update="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
      <Generator>VsixManifestGenerator</Generator>
      <LastGenOutput>source.extension.cs</LastGenOutput>
    </None>
  </ItemGroup>

