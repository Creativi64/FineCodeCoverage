  <!-- Referencing the v18 TestWindow.Interfaces from the installed VS pulls in v18 Microsoft.VisualStudio.GraphModel,
       which RAR flags (MSB3277) against the v17.14 Microsoft.VisualStudio.SDK packages.  There is no v18 VS SDK
       (Microsoft ships only 17.x; VS2026 runs 17-SDK extensions via back-compat), so this conflict can't be
       "fixed" by a version bump.  It is harmless - the VS2026 host provides and unifies a single v18 GraphModel at
       runtime - so the warning is downgraded to a message here. -->
  <PropertyGroup>
    <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MSB3277</MSBuildWarningsAsMessages>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft.VisualStudio.TestWindow.Interfaces is not on NuGet at a usable version (the package is
         frozen at v11.x - an API downgrade), and it can't be vendored as local C# either: the types here
         (ITestContainerDiscoverer, IRunSettingsService, IOperation, IOperationState, ...) are MEF contracts
         exchanged with the VS host (see [Export]/[Import] in SharedProject\Collection), so a copy with a
         different assembly identity would break MEF composition and the test-explorer / MS Code Coverage
         integration.  Instead we reference the real assembly straight out of the installed VS via
         $(VsInstallRoot).  This is safe because the VSIX targets a single VS major (see the [18.0,19.0)
         InstallationTarget in source.extension.vsixmanifest), so the build machine's VS and the runtime host
         are the same major version.  SpecificVersion=False so it unifies with the host at runtime. -->
    <Reference Include="Microsoft.VisualStudio.TestWindow.Interfaces, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL">
      <SpecificVersion>False</SpecificVersion>
      <HintPath>$(VsInstallRoot)\Common7\IDE\CommonExtensions\Microsoft\TestWindow\Microsoft.VisualStudio.TestWindow.Interfaces.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="System.Design" />
    <Reference Include="System.IO.Compression.FileSystem" />
  </ItemGroup>

