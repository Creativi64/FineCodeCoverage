<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:FineCodeCoverage.Readme"
    xmlns:markdigExtended="clr-namespace:MarkdigExtended.NotifyingWpfRenderers.Base;assembly=MarkdigExtended"
    xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:vsShell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Style
        x:Key="{x:Static markdigExtended:MarkdownTypeMarker.CodeInline}"
        BasedOn="{StaticResource {x:Static local:ReadMeFlowDocumentStyleSetter.ReadMeCodeInlineBasedOnStyleKey}}"
        TargetType="{x:Type Run}">
        <Setter Property="Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}" />
    </Style>
</ResourceDictionary>