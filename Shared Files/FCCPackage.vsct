		<IDSymbol value="14" name="cmdidOpenSettingsCommand" />
		<IDSymbol value="15" name="cmdidResetSettingsCommand" />
	
		<IDSymbol value="16" name="cmdidCollectTUnitCommand" />
		<IDSymbol value="17" name="cmdidCancelCollectTUnitCommand" />
	</GuidSymbol>

	<!-- from Monikers.imagemanifest -->
	<GuidSymbol name="guidMonikers" value="{c07b27ae-9756-4632-a6e6-1578f6dfbedf}">
		<IDSymbol name="openReportWindowCommandImageIndex" value="1" />
		<IDSymbol name="clearUICommandImageIndex" value="6" />
