<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Binding redirects are generated automatically at build time (AutoGenerateBindingRedirects +
    GenerateBindingRedirectsOutputType in the .csproj).  Do not hand-maintain <bindingRedirect>
    entries here - stale hand-written redirects (e.g. Moq pinned to a version that is no longer
    restored) cause FileLoadException at test run time.
  -->
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/></startup></configuration>
