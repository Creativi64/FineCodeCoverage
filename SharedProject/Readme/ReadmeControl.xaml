<UserControl
  x:Class="FineCodeCoverage.Readme.ReadmeControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sfdr="clr-namespace:StylableFindFlowDocumentReader;assembly=StylableFindFlowDocumentReader"
  Name="readmeControl"
  d:DesignHeight="300"
  d:DesignWidth="300"
  mc:Ignorable="d">
    <sfdr:FindRestylingFlowDocumentReader x:Name="findRestylingFlowDocumentReader"
    Document="{Binding ElementName=readmeControl, Path=DataContext.FlowDocument}"
    ScrollViewer.VerticalScrollBarVisibility="Auto"
    ViewingMode="Scroll" />
</UserControl>
