<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:FineCodeCoverage.Readme"
  xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
  xmlns:vsShell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
  xmlns:markdigExtended="clr-namespace:MarkdigExtended.NotifyingWpfRenderers.Base;assembly=MarkdigExtended"
  xmlns:readmeConverters="clr-namespace:FineCodeCoverage.Readme.Converters;assembly=FineCodeCoverage.Readme"
  xmlns:sfdr="clr-namespace:EnhancedFlowDocumentControls.FlowDocumentControls;assembly=EnhancedFlowDocumentControls"
  xmlns:findControls="clr-namespace:EnhancedFlowDocumentControls.FindToolBarControls;assembly=EnhancedFlowDocumentControls"
  xmlns:sysInput="clr-namespace:System.Windows.Input;assembly=PresentationCore">
  <!--  visual studio 2022 has a resource dictionary Source="/Microsoft.VisualStudio.Shell.UI.Internal;component/Common/Markdown/ThemedMarkdig.xaml"  -->
  <!--  although the What's New Page overrides the style of the flow document to use Environment111PercentFontSizeKey  -->
  <readmeConverters:HyperlinkContainsImageConverter
    x:Key="HyperlinkContainsImageConverter" />
  <Style
    x:Key="HyperlinkFocusVisualStyle">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Rectangle
            Margin="-2,-1"
            SnapsToDevicePixels="true"
            Stroke="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}"
            StrokeDashArray="1 2"
            StrokeThickness="1" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.FlowDocument}"
    TargetType="{x:Type FlowDocument}">
    <Setter Property="FlowDocument.FontFamily" Value="{DynamicResource {x:Static vsShell:VsFonts.EnvironmentFontFamilyKey}}" />
    <Setter Property="FlowDocument.FontSize" Value="{DynamicResource {x:Static vsShell:VsFonts.EnvironmentFontSizeKey}}" />
    <Setter Property="FlowDocument.TextAlignment" Value="Left" />
    <Setter Property="FlowDocument.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="FlowDocument.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="ContentElement.Focusable" Value="False" />
    <!--  FCC  -->
    <Setter Property="IsOptimalParagraphEnabled" Value="true" />
    <Setter Property="IsHyphenationEnabled" Value="true" />
  </Style>
  <Style
    TargetType="{x:Type List}">
    <Setter Property="Block.Margin" Value="40,0,0,0" />
    <Setter Property="Block.Padding" Value="0,0,0,0" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.CodeBlock}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="Block.Padding" Value="10" />
    <Setter Property="Block.BorderThickness" Value="1" />
    <Setter Property="Block.BorderBrush" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBorderBrushKey}}" />
    <!--  why not use ToolWindowCodeBlockBackgroundBrushKey as per code inline ?  -->
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowContentGridBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontFamily" Value="Consolas, Lucida Sans Typewriter, Courier New" />
  </Style>
  <Style
    x:Key="{x:Static local:ReadMeFlowDocumentStyleSetter.ReadMeCodeInlineBasedOnStyleKey}"
    TargetType="{x:Type Run}">
    <!--  separate versions 2019 and 2022  -->
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontFamily" Value="Consolas, Lucida Sans Typewriter, Courier New" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock1}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="TextElement.FontSize" Value="{DynamicResource {x:Static vsShell:VsFonts.Environment283PercentFontSizeKey}}" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontWeight" Value="Bold" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock2}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="TextElement.FontSize" Value="{DynamicResource {x:Static vsShell:VsFonts.Environment200PercentFontSizeKey}}" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontWeight" Value="Bold" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock3}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="TextElement.FontSize" Value="{DynamicResource {x:Static vsShell:VsFonts.Environment133PercentFontSizeKey}}" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontWeight" Value="Bold" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock4}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="TextElement.FontSize" Value="{DynamicResource {x:Static vsShell:VsFonts.Environment133PercentFontSizeKey}}" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="TextElement.FontWeight" Value="Light" />
    <Setter Property="Paragraph.TextDecorations" Value="Underline" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock5}"
    TargetType="{x:Type Paragraph}" />
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.HeadingBlock6}"
    TargetType="{x:Type Paragraph}" />

  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.LinkInlineHyperlink}"
    TargetType="{x:Type Hyperlink}">
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:CommonDocumentColors.HyperlinkBrushKey}}" />
    <Setter Property="FrameworkContentElement.FocusVisualStyle" Value="{StaticResource HyperlinkFocusVisualStyle}" />

    <Style.Triggers>
      <DataTrigger
        Value="True">
        <DataTrigger.Binding>
          <Binding
            Converter="{StaticResource HyperlinkContainsImageConverter}"
            Path="Inlines"
            RelativeSource="{RelativeSource Self}" />
        </DataTrigger.Binding>
        <Setter Property="Inline.TextDecorations" Value="None" />
      </DataTrigger>
      <DataTrigger
        Value="True">
        <DataTrigger.Binding>
          <Binding
            Path="ShowHyperlinkUrlHover" />
        </DataTrigger.Binding>
        <Setter Property="ToolTip" Value="{Binding NavigateUri, RelativeSource={RelativeSource Self}}" />
      </DataTrigger>
    </Style.Triggers>

  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.LinkInlineImage}"
    TargetType="{x:Type Image}">
    <Setter Property="FrameworkElement.MaxHeight">
      <Setter.Value>
        <Binding
          Path="Source.(BitmapSource.PixelHeight)"
          RelativeSource="{RelativeSource Self}" />
      </Setter.Value>
    </Setter>
    <Setter Property="FrameworkElement.MaxWidth">
      <Setter.Value>
        <Binding
          Path="Source.(BitmapSource.PixelWidth)"
          RelativeSource="{RelativeSource Self}" />
      </Setter.Value>
    </Setter>
    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.Paragraph}"
    TargetType="{x:Type Paragraph}">
    <Setter Property="Block.Margin" Value="0,8,0,8" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.QuoteBlock}"
    TargetType="{x:Type Section}">
    <Setter Property="Block.BorderBrush" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBorderBrushKey}}" />
    <Setter Property="Block.BorderThickness" Value="4,0,0,0" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolboxContentTextBrushKey}}" />
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolboxContentBrushKey}}" />
    <Setter Property="Block.Padding" Value="16,0,0,0" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.Table}"
    TargetType="{x:Type Table}">
    <Setter Property="Block.BorderBrush" Value="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxBorderBrushKey}}" />
    <Setter Property="Block.BorderThickness" Value="0,0,1,1" />
    <Setter Property="Table.CellSpacing" Value="0" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.TableCell}"
    TargetType="{x:Type TableCell}">
    <Setter Property="TableCell.BorderBrush" Value="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxBorderBrushKey}}" />
    <Setter Property="TableCell.BorderThickness" Value="1,1,0,0" />
    <Setter Property="Padding" Value="10,0,10,0" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.TableHeader}"
    TargetType="{x:Type TableRow}">
    <Setter Property="TextElement.FontWeight" Value="Bold" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.TaskList}"
    TargetType="{x:Type CheckBox}">
    <Setter Property="FrameworkElement.Margin" Value="0,0,0,-2" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.ThematicBreakBlock}"
    TargetType="{x:Type Line}">
    <Setter Property="Shape.Stretch" Value="Fill" />
    <Setter Property="Shape.Stroke" Value="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ComboBoxGlyphBrushKey}}" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.EmphasisInlineSubscript}"
    TargetType="{x:Type Span}">
    <Setter Property="Typography.Variants" Value="Subscript" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.EmphasisInlineSuperscript}"
    TargetType="{x:Type Span}">
    <Setter Property="Typography.Variants" Value="Superscript" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.EmphasisInlineStrikeThrough}"
    TargetType="{x:Type Span}">
    <Setter Property="TextBlock.TextDecorations" Value="Strikethrough" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.EmphasisInlineInserted}"
    TargetType="{x:Type Span}">
    <Setter Property="TextBlock.TextDecorations" Value="Underline" />
  </Style>
  <Style
    x:Key="{x:Static markdigExtended:MarkdownTypeMarker.EmphasisInlineMarked}"
    TargetType="{x:Type Span}">
    <Setter Property="TextElement.Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.SystemHighlightBrushKey}}" />
  </Style>
  <Style
    x:Key="FlowDocumentReaderFocusVisualStyle">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Rectangle
            Margin="0"
            SnapsToDevicePixels="true"
            Stroke="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}"
            StrokeDashArray="1 2"
            StrokeThickness="1" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    TargetType="{x:Type sfdr:EnhancedFlowDocumentReader}">
    <Style.Resources>
            <Style
        TargetType="ToolTip">
                <Setter Property="FontFamily" Value="{DynamicResource ResourceKey={x:Static vsShell:VsFonts.EnvironmentFontFamilyKey}}" />
                <Setter Property="FontSize" Value="{DynamicResource ResourceKey={x:Static vsShell:VsFonts.EnvironmentFontSizeKey}}" />
                <Setter Property="Background" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolTipBrushKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolTipTextBrushKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolTipBorderBrushKey}}" />
            </Style>

        </Style.Resources>
    <Setter Property="FocusVisualStyle" Value="{StaticResource FlowDocumentReaderFocusVisualStyle}" />
    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
    <Setter Property="FindToolBar">
      <Setter.Value>
        <findControls:FindToolBar Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxBackgroundBrushKey}}">
          <findControls:FindToolBar.Resources>
                        <Style
    x:Key="FindButtonFocusVisual">
                            <Setter Property="Control.Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Rectangle
            Margin="0"
            SnapsToDevicePixels="true"
            Stroke="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxTextBrushKey}}"
            StrokeDashArray="1 2"
            StrokeThickness="1" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </findControls:FindToolBar.Resources>
          <Border x:Name="FindTextBoxBorder"
            Margin="5,0,15,0"
            Padding="0"
            Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxBackgroundBrushKey}}"
            BorderBrush="Transparent"
            BorderThickness="1"
            SnapsToDevicePixels="true">
            <StackPanel
              Orientation="Horizontal">
              <findControls:FindTextBox
                SelectionBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.SystemHighlightBrushKey}}"
                Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxBackgroundBrushKey}}"
                Foreground="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.TextBoxTextBrushKey}}" />
              <findControls:FindNextPreviousButtons
                FocusVisualStyle="{StaticResource FindButtonFocusVisual}"
                Foreground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}" />
              <findControls:FindMenu
                DropDownFocusVisualStyle="{StaticResource FindButtonFocusVisual}"
                DropDownBackgroundPressed="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownButtonMouseDownBackgroundBrushKey}}"
                DropDownBorderPressedBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownButtonMouseDownSeparatorBrushKey}}"
                DropDownGlyphBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownGlyphBrushKey}}"
                DropDownGlyphDisabledBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownDisabledGlyphBrushKey}}"
                DropDownGlyphPressedBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownMouseDownGlyphBrushKey}}"
                DropDownStateBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownButtonMouseOverBackgroundBrushKey}}"
                DropDownStateBorderBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownButtonMouseOverSeparatorBrushKey}}"
                DropDownStateGlyphBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownMouseOverGlyphBrushKey}}"
                MenuBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownPopupBackgroundGradientBrushKey}}"
                MenuBorderBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.DropDownPopupBorderBrushKey}}"
                MenuItemBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuBackgroundGradientBeginBrushKey}}"
                MenuItemBorderBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuBorderBrushKey}}"
                MenuItemForeground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarTextActiveBrushKey}}"
                MenuItemHighlightedBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuItemMouseOverBrushKey}}"
                MenuItemHighlightedBorderBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuItemMouseOverBorderBrushKey}}"
                MenuItemHighlightedForeground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuItemMouseOverTextBrushKey}}"
                SelectedGlyphBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuIconBackgroundBrushKey}}"
                SelectedGlyphBorderBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuBorderBrushKey}}"
                SelectedGlyphBrush="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}" />
            </StackPanel>
          </Border>
        </findControls:FindToolBar>
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <ControlTemplate.Resources>
            <LinearGradientBrush x:Key="PUIFlowViewers_ZoomButtonUpBrush" StartPoint="0,0" EndPoint="0,1">
              <GradientBrush.GradientStops>
                <GradientStop Offset="0" Color="#9fff" />
                <GradientStop Offset="1" Color="#6000" />
              </GradientBrush.GradientStops>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="PUIFlowViewers_ZoomButtonDownBrush" StartPoint="0,0" EndPoint="0,1">
              <GradientBrush.GradientStops>
                <GradientStop Offset="0" Color="#9000" />
                <GradientStop Offset="1" Color="#6fff" />
              </GradientBrush.GradientStops>
            </LinearGradientBrush>
            <PathGeometry
              x:Key="PUIFlowViewers_UpArrowIcon">
              <PathFigure
                IsClosed="true"
                StartPoint="5,0">
                <LineSegment
                  IsStroked="true"
                  Point="5,10" />
                <LineSegment
                  IsStroked="true"
                  Point="0,5" />
              </PathFigure>
            </PathGeometry>
            <PathGeometry
              x:Key="PUIFlowViewers_DownArrowIcon">
              <PathFigure
                IsClosed="true"
                StartPoint="0,0">
                <LineSegment
                  IsStroked="true"
                  Point="0,10" />
                <LineSegment
                  IsStroked="true"
                  Point="5,5" />
              </PathFigure>
            </PathGeometry>
            <Style
              x:Key="PUIFlowViewers_GrowShrinkOpacityButtonBase"
              BasedOn="{x:Null}"
              TargetType="{x:Type ButtonBase}">
              <Setter Property="UIElement.Focusable" Value="false" />
              <Setter Property="UIElement.Opacity" Value=".5" />
              <Setter Property="FrameworkElement.Cursor" Value="Hand" />
              <Setter Property="Control.Background" Value="Transparent" />
              <Setter Property="Control.Padding" Value="3,1" />
              <Setter Property="Control.BorderBrush" Value="{x:Null}" />
              <Setter Property="Control.BorderThickness" Value="0" />
              <Setter Property="FrameworkElement.MinWidth" Value="0" />
              <Setter Property="FrameworkElement.MinHeight" Value="0" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type ButtonBase}">
                    <Border
                      Background="{TemplateBinding Control.Background}">
                      <ContentPresenter x:Name="Content"
                        RenderTransformOrigin=".5, .5" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="UIElement.IsMouseOver" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                      <Trigger Property="ButtonBase.IsPressed" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX=".9" ScaleY=".9" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="UIElement.IsEnabled" Value="false">
                  <Setter Property="UIElement.Opacity" Value=".3" />
                </Trigger>
                <Trigger Property="UIElement.IsMouseOver" Value="true">
                  <Setter Property="UIElement.Opacity" Value="1" />
                </Trigger>
              </Style.Triggers>
            </Style>
            <Style
              x:Key="PUIFlowViewers_GrowShrinkOpacityToggleButton"
              BasedOn="{StaticResource PUIFlowViewers_GrowShrinkOpacityButtonBase}"
              TargetType="{x:Type ToggleButton}">
              <Style.Triggers>
                <Trigger Property="UIElement.IsEnabled" Value="false">
                  <Setter Property="UIElement.Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="ToggleButton.IsChecked" Value="True">
                  <Setter Property="UIElement.Opacity" Value="1" />
                </Trigger>
              </Style.Triggers>
            </Style>
            <Style
              x:Key="PUIFlowViewers_GrowShrinkOpacityRadioButton"
              BasedOn="{StaticResource PUIFlowViewers_GrowShrinkOpacityToggleButton}"
              TargetType="{x:Type RadioButton}">
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type RadioButton}">
                    <Border
                      Padding="{TemplateBinding Control.Padding}"
                      Background="{TemplateBinding Control.Background}"
                      BorderBrush="{TemplateBinding Control.BorderBrush}"
                      BorderThickness="{TemplateBinding Control.BorderThickness}">
                      <ContentPresenter x:Name="Content"
                        RenderTransformOrigin=".5, .5" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="ButtonBase.IsPressed" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX=".9" ScaleY=".9" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
            <Style
              x:Key="PUIFlowViewers_GrowShrinkOpacityRepeatButton"
              BasedOn="{StaticResource PUIFlowViewers_GrowShrinkOpacityButtonBase}"
              TargetType="{x:Type RepeatButton}">
              <Setter Property="Control.Padding" Value="5" />
              <Setter Property="RepeatButton.Delay" Value="1000" />
              <Setter Property="RepeatButton.Interval" Value="250" />
            </Style>
            <Style
              x:Key="PUIFlowViewers_ZoomOutButton"
              BasedOn="{StaticResource PUIFlowViewers_GrowShrinkOpacityRepeatButton}"
              TargetType="{x:Type RepeatButton}">
              <Setter Property="Control.Padding" Value="2,2,0,2" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type RepeatButton}">
                    <Border
                      Padding="{Binding Path=Padding, RelativeSource={RelativeSource TemplatedParent}}"
                      Background="Transparent">
                      <Viewbox x:Name="Content"
                        RenderTransformOrigin=".5,.5">
                        <Canvas
                          Width="32"
                          Height="32">
                          <Path
                            Width="32"
                            Height="32"
                            Fill="{Binding Path=Background, RelativeSource={RelativeSource TemplatedParent}}">
                            <Path.Data>
                              <GeometryGroup>
                                <EllipseGeometry
                                  Center="16,16"
                                  RadiusX="16"
                                  RadiusY="16" />
                              </GeometryGroup>
                            </Path.Data>
                          </Path>
                          <Path x:Name="Sheen"
                            Width="32"
                            Height="32"
                            Fill="{StaticResource PUIFlowViewers_ZoomButtonUpBrush}">
                            <Path.Data>
                              <GeometryGroup>
                                <EllipseGeometry
                                  Center="16,16"
                                  RadiusX="16"
                                  RadiusY="16" />
                              </GeometryGroup>
                            </Path.Data>
                          </Path>
                          <Path
                            Canvas.Left="16"
                            Canvas.Top="16"
                            Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                            StrokeThickness="5">
                            <Path.Data>
                              <LineGeometry
                                StartPoint="-10,0"
                                EndPoint="10,0" />
                            </Path.Data>
                          </Path>
                        </Canvas>
                      </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="UIElement.IsMouseOver" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                      <Trigger Property="ButtonBase.IsPressed" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                          </Setter.Value>
                        </Setter>
                        <Setter TargetName="Sheen" Property="Shape.Fill" Value="{StaticResource PUIFlowViewers_ZoomButtonDownBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
            <Style
              x:Key="PUIFlowViewers_ZoomInButton"
              BasedOn="{StaticResource PUIFlowViewers_GrowShrinkOpacityRepeatButton}"
              TargetType="{x:Type RepeatButton}">
              <Setter Property="Control.Padding" Value="0,2,2,2" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type RepeatButton}">
                    <Border
                      Padding="{Binding Path=Padding, RelativeSource={RelativeSource TemplatedParent}}"
                      Background="Transparent">
                      <Viewbox x:Name="Content"
                        RenderTransformOrigin=".5,.5">
                        <Canvas
                          Width="32"
                          Height="32">
                          <Path
                            Width="32"
                            Height="32"
                            Fill="{Binding Path=Background, RelativeSource={RelativeSource TemplatedParent}}">
                            <Path.Data>
                              <GeometryGroup>
                                <EllipseGeometry
                                  Center="16,16"
                                  RadiusX="16"
                                  RadiusY="16" />
                              </GeometryGroup>
                            </Path.Data>
                          </Path>
                          <Path x:Name="Sheen"
                            Width="32"
                            Height="32"
                            Fill="{StaticResource PUIFlowViewers_ZoomButtonUpBrush}">
                            <Path.Data>
                              <GeometryGroup>
                                <EllipseGeometry
                                  Center="16,16"
                                  RadiusX="16"
                                  RadiusY="16" />
                              </GeometryGroup>
                            </Path.Data>
                          </Path>
                          <Path
                            Canvas.Left="16"
                            Canvas.Top="16"
                            Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                            StrokeThickness="5">
                            <Path.Data>
                              <GeometryGroup>
                                <LineGeometry
                                  StartPoint="-10,0"
                                  EndPoint="10,0" />
                                <LineGeometry
                                  StartPoint="0,-10"
                                  EndPoint="0,10" />
                              </GeometryGroup>
                            </Path.Data>
                          </Path>
                        </Canvas>
                      </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="UIElement.IsMouseOver" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                      <Trigger Property="ButtonBase.IsPressed" Value="true">
                        <Setter TargetName="Content" Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                          </Setter.Value>
                        </Setter>
                        <Setter TargetName="Sheen" Property="Shape.Fill" Value="{StaticResource PUIFlowViewers_ZoomButtonDownBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
            <Style
              x:Key="PUIFlowViewers_Slider_RepeatButton"
              TargetType="{x:Type RepeatButton}">
              <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true" />
              <Setter Property="Control.IsTabStop" Value="false" />
              <Setter Property="UIElement.Focusable" Value="false" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type RepeatButton}">
                    <Border
                      Background="Transparent" />
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
            <PathGeometry
              x:Key="PUIFlowViewers_Slider_ThumbGeometry"
              FillRule="Nonzero">
              <PathFigure
                IsClosed="true"
                StartPoint="1,0">
                <LineSegment
                  Point="10,0" />
                <LineSegment
                  Point="11,1" />
                <LineSegment
                  Point="11,13" />
                <LineSegment
                  Point="6.5,17" />
                <LineSegment
                  Point="4.5,17" />
                <LineSegment
                  Point="0,13" />
                <LineSegment
                  Point="0,1" />
                <LineSegment
                  Point="1,0" />
              </PathFigure>
            </PathGeometry>
            <Style
              x:Key="PUIFlowViewers_Slider_Thumb"
              TargetType="{x:Type Thumb}">
              <Setter Property="Control.Background" Value="{Binding Path=Background, RelativeSource={RelativeSource TemplatedParent}}" />
              <Setter Property="UIElement.Focusable" Value="false" />
              <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true" />
              <Setter Property="FrameworkElement.Cursor" Value="Hand" />
              <Setter Property="Control.Padding" Value="6" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type Thumb}">
                    <Border
                      Margin="-2"
                      Padding="{Binding Path=Padding, RelativeSource={RelativeSource TemplatedParent}}"
                      Background="Transparent">
                      <Viewbox
                        Width="{Binding Path=FontSize, RelativeSource={RelativeSource TemplatedParent}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <FrameworkElement.LayoutTransform>
                          <ScaleTransform ScaleX="1" ScaleY="1" />
                        </FrameworkElement.LayoutTransform>
                        <Canvas
                          Width="13"
                          Height="17">
                          <Path
                            Data="{StaticResource PUIFlowViewers_Slider_ThumbGeometry}"
                            Fill="{Binding Path=Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                          <Path
                            Data="{StaticResource PUIFlowViewers_Slider_ThumbGeometry}"
                            Stroke="{TemplateBinding Control.Background}"
                            StrokeDashCap="Round"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeMiterLimit="1"
                            StrokeThickness=".75">
                            <Shape.Fill>
                              <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientBrush.GradientStops>
                                  <GradientStopCollection>
                                    <GradientStop Offset="0.5" Color="#c999" />
                                    <GradientStop Offset="0.8" Color="#cfff" />
                                    <GradientStop Offset="0.2" Color="#cfff" />
                                  </GradientStopCollection>
                                </GradientBrush.GradientStops>
                                <Brush.RelativeTransform>
                                  <TransformGroup>
                                    <TranslateTransform X="-0.5" Y="-0.5" />
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                    <SkewTransform AngleX="0" AngleY="0" />
                                    <RotateTransform Angle="110" />
                                    <TranslateTransform X="0.5" Y="0.5" />
                                  </TransformGroup>
                                </Brush.RelativeTransform>
                              </LinearGradientBrush>
                            </Shape.Fill>
                          </Path>
                        </Canvas>
                      </Viewbox>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
            <Style
              x:Key="PUIFlowViewers_Slider"
              TargetType="{x:Type Slider}">
              <Setter Property="sysInput:Stylus.IsPressAndHoldEnabled" Value="false" />
              <Setter Property="UIElement.Focusable" Value="false" />
              <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true" />
              <Setter Property="Control.Background" Value="{Binding Path=Background, RelativeSource={RelativeSource TemplatedParent}}" />
              <Setter Property="Control.BorderThickness" Value="1" />
              <Setter Property="Control.BorderBrush" Value="#0000" />
              <Setter Property="Control.Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
              <Setter Property="Slider.IsSnapToTickEnabled" Value="true" />
              <Setter Property="UIElement.RenderTransformOrigin" Value=".5,.5" />
              <Setter Property="FrameworkElement.MinWidth" Value="50" />
              <Setter Property="FrameworkElement.MinHeight" Value="0" />
              <Setter Property="FrameworkElement.Width" Value="Auto" />
              <Setter Property="Control.Padding" Value="2,0" />
              <Setter Property="FrameworkElement.Height" Value="Auto" />
              <Setter Property="UIElement.Opacity" Value=".75" />
              <Setter Property="Slider.Delay" Value="1000" />
              <Setter Property="Slider.Interval" Value="250" />
              <Setter Property="Control.Template">
                <Setter.Value>
                  <ControlTemplate
                    TargetType="{x:Type Slider}">
                    <Border
                      Padding="{TemplateBinding Control.Padding}"
                      Background="Transparent">
                      <Grid
                        ClipToBounds="false">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition
                            Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition
                            Height="Auto" />
                          <RowDefinition
                            Height="Auto"
                            MinHeight="{TemplateBinding FrameworkElement.MinHeight}" />
                          <RowDefinition
                            Height="Auto" />
                          <RowDefinition
                            Height="*" />
                        </Grid.RowDefinitions>
                        <TickBar x:Name="TopTick"
                          Grid.Row="0"
                          Height="4"
                          Fill="{TemplateBinding Control.Foreground}"
                          Placement="Top"
                          Visibility="Collapsed" />
                        <Border
                          Grid.Row="1"
                          Height="2"
                          Background="{TemplateBinding Control.Foreground}"
                          CornerRadius="2"
                          Opacity=".5" />
                        <Canvas
                          Grid.Row="1"
                          Height="4"
                          VerticalAlignment="Center">
                          <Rectangle x:Name="PART_SelectionRange"
                            Canvas.Top="1"
                            Height="2.0"
                            Fill="{TemplateBinding Control.Foreground}"
                            Visibility="Hidden" />
                        </Canvas>
                        <Track
                          Name="PART_Track"
                          Grid.Row="1">
                          <Track.DecreaseRepeatButton>
                            <RepeatButton
                              Command="Slider.DecreaseLarge"
                              Style="{StaticResource PUIFlowViewers_Slider_RepeatButton}" />
                          </Track.DecreaseRepeatButton>
                          <Track.Thumb>
                            <Thumb
                              Background="{TemplateBinding Control.Background}"
                              Style="{StaticResource PUIFlowViewers_Slider_Thumb}" />
                          </Track.Thumb>
                          <Track.IncreaseRepeatButton>
                            <RepeatButton
                              Command="Slider.IncreaseLarge"
                              Style="{StaticResource PUIFlowViewers_Slider_RepeatButton}" />
                          </Track.IncreaseRepeatButton>
                        </Track>
                        <TickBar x:Name="BottomTick"
                          Grid.Row="2"
                          Height="4"
                          Fill="{TemplateBinding Control.Foreground}"
                          Placement="Bottom"
                          Visibility="Collapsed" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="Slider.TickPlacement" Value="TopLeft">
                        <Setter TargetName="TopTick" Property="UIElement.Visibility" Value="Visible" />
                      </Trigger>
                      <Trigger Property="Slider.TickPlacement" Value="BottomRight">
                        <Setter TargetName="BottomTick" Property="UIElement.Visibility" Value="Visible" />
                      </Trigger>
                      <Trigger Property="Slider.TickPlacement" Value="Both">
                        <Setter TargetName="TopTick" Property="UIElement.Visibility" Value="Visible" />
                        <Setter TargetName="BottomTick" Property="UIElement.Visibility" Value="Visible" />
                      </Trigger>
                      <Trigger Property="Slider.IsSelectionRangeEnabled" Value="true">
                        <Setter TargetName="PART_SelectionRange" Property="UIElement.Visibility" Value="Visible" />
                      </Trigger>
                      <Trigger Property="UIElement.IsMouseOver" Value="true">
                        <Setter Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                      <Trigger Property="UIElement.IsMouseOver" Value="true">
                        <Setter Property="UIElement.Opacity" Value="1" />
                        <Setter Property="UIElement.RenderTransform">
                          <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                          </Setter.Value>
                        </Setter>
                      </Trigger>
                      <Trigger Property="UIElement.IsEnabled" Value="false">
                        <Setter Property="UIElement.Opacity" Value=".3" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>

          </ControlTemplate.Resources>
          <DockPanel
            xml:lang="en-US"
            LastChildFill="true">
            <Grid
              DockPanel.Dock="Bottom"
              HorizontalAlignment="Stretch"
              Background="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandShelfBackgroundGradientBrushKey}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition
                  Width="*" />
                <ColumnDefinition
                  Width="Auto" />
                <ColumnDefinition
                  Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel x:Name="FindButtonAndToolbar"
                Grid.Row="0"
                Grid.Column="0"
                Orientation="Horizontal">
                <ToggleButton x:Name="FindButton"
                  Command="Find"
                  Margin="3,0,3,0"
                  Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityToggleButton}"
                  Focusable="false"
                  ToolTip="Find">
                  <Path
                    VerticalAlignment="Center"
                    Stroke="{TemplateBinding Control.Foreground}">
                    <Path.Data>
                      <GeometryGroup>
                        <RectangleGeometry
                          RadiusX="1"
                          RadiusY="1"
                          Rect=".5,.5 19,19" />
                        <EllipseGeometry
                          Center="12,8"
                          RadiusX="5"
                          RadiusY="5" />
                        <EllipseGeometry
                          Center="12,8"
                          RadiusX="4"
                          RadiusY="4" />
                        <LineGeometry
                          StartPoint="2.5,16.5"
                          EndPoint="9,10" />
                        <LineGeometry
                          StartPoint="3,17"
                          EndPoint="9.5,10.5" />
                        <LineGeometry
                          StartPoint="3.5,17.5"
                          EndPoint="10,11" />
                      </GeometryGroup>
                    </Path.Data>
                  </Path>
                </ToggleButton>
                <Border x:Name="PART_FindToolBarHost"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Visibility="Collapsed" />
              </StackPanel>
              <StackPanel x:Name="PageCountAndButtons"
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <RepeatButton x:Name="PreviousPage"
                  Command="NavigationCommands.PreviousPage"
                  Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityRepeatButton}"
                  IsEnabled="{TemplateBinding FlowDocumentReader.CanGoToPreviousPage}"
                  ToolTip="Previous Page">
                  <Viewbox
                    Height="{TemplateBinding Control.FontSize}">
                    <Path
                      Fill="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}">
                      <Path.Data>
                        <StaticResource
                          ResourceKey="PUIFlowViewers_UpArrowIcon" />
                      </Path.Data>
                    </Path>
                  </Viewbox>
                </RepeatButton>
                <TextBlock x:Name="PageXOfY"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                  <Run
                    xml:space="preserve"> </Run>
                  <TextBlock
                    Text="{Binding Path=PageNumber, RelativeSource={RelativeSource TemplatedParent}}" />
                  <Run
                    xml:space="preserve"> of </Run>
                  <TextBlock
                    Text="{Binding Path=PageCount, RelativeSource={RelativeSource TemplatedParent}}" />
                  <Run
                    xml:space="preserve"> </Run>
                </TextBlock>
                <RepeatButton x:Name="NextPage"
                  Command="NavigationCommands.NextPage"
                  Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityRepeatButton}"
                  IsEnabled="{TemplateBinding FlowDocumentReader.CanGoToNextPage}"
                  ToolTip="Next Page">
                  <Viewbox
                    Height="{TemplateBinding Control.FontSize}">
                    <Path
                      Fill="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}">
                      <Path.Data>
                        <StaticResource
                          ResourceKey="PUIFlowViewers_DownArrowIcon" />
                      </Path.Data>
                    </Path>
                  </Viewbox>
                </RepeatButton>
              </StackPanel>
              <Grid x:Name="PageViewButtonsAndZoom"
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition
                    Width="Auto" />
                  <ColumnDefinition
                    Width="Auto" />
                  <ColumnDefinition />
                  <ColumnDefinition
                    Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="PageViewButtons"
                  Orientation="Horizontal">
                  <RadioButton x:Name="PageViewButton"
                    Command="FlowDocumentReader.SwitchViewingModeCommand"
                    CommandParameter="Page"
                    Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityRadioButton}"
                    GroupName="ViewingMode"
                    IsEnabled="{TemplateBinding FlowDocumentReader.IsPageViewEnabled}"
                    ToolTip="Page Mode">
                    <Path
                      VerticalAlignment="Center"
                      Stroke="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}">
                      <Path.Data>
                        <GeometryGroup>
                          <RectangleGeometry
                            RadiusX="1"
                            RadiusY="1"
                            Rect=".5,.5 19,19" />
                          <RectangleGeometry
                            Rect="4.5,3.5 11, 13" />
                          <LineGeometry
                            StartPoint="4.5,4.5"
                            EndPoint="15.5,4.5" />
                          <LineGeometry
                            StartPoint="4.5,6.5"
                            EndPoint="15.5,6.5" />
                          <LineGeometry
                            StartPoint="4.5,8.5"
                            EndPoint="15.5,8.5" />
                          <LineGeometry
                            StartPoint="4.5,10.5"
                            EndPoint="15.5,10.5" />
                          <LineGeometry
                            StartPoint="4.5,12.5"
                            EndPoint="15.5,12.5" />
                          <LineGeometry
                            StartPoint="4.5,14.5"
                            EndPoint="15.5,14.5" />
                        </GeometryGroup>
                      </Path.Data>
                    </Path>
                  </RadioButton>
                  <RadioButton x:Name="TwoPageViewButton"
                    Command="FlowDocumentReader.SwitchViewingModeCommand"
                    CommandParameter="TwoPage"
                    Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityRadioButton}"
                    GroupName="ViewingMode"
                    IsEnabled="{TemplateBinding FlowDocumentReader.IsTwoPageViewEnabled}"
                    ToolTip="Two Page Mode">
                    <Path
                      VerticalAlignment="Center"
                      Stroke="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}">
                      <Path.Data>
                        <GeometryGroup>
                          <RectangleGeometry
                            RadiusX="1"
                            RadiusY="1"
                            Rect=".5,.5 19,19" />
                          <RectangleGeometry
                            Rect="3.5,3.5 5, 13" />
                          <LineGeometry
                            StartPoint="3.5,4.5"
                            EndPoint="8.5,4.5" />
                          <LineGeometry
                            StartPoint="3.5,6.5"
                            EndPoint="8.5,6.5" />
                          <LineGeometry
                            StartPoint="3.5,8.5"
                            EndPoint="8.5,8.5" />
                          <LineGeometry
                            StartPoint="3.5,10.5"
                            EndPoint="8.5,10.5" />
                          <LineGeometry
                            StartPoint="3.5,12.5"
                            EndPoint="8.5,12.5" />
                          <LineGeometry
                            StartPoint="3.5,14.5"
                            EndPoint="8.5,14.5" />
                          <RectangleGeometry
                            Rect="11.5,3.5 5, 13" />
                          <LineGeometry
                            StartPoint="11.5,4.5"
                            EndPoint="16.5,4.5" />
                          <LineGeometry
                            StartPoint="11.5,6.5"
                            EndPoint="16.5,6.5" />
                          <LineGeometry
                            StartPoint="11.5,8.5"
                            EndPoint="16.5,8.5" />
                          <LineGeometry
                            StartPoint="11.5,10.5"
                            EndPoint="16.5,10.5" />
                          <LineGeometry
                            StartPoint="11.5,12.5"
                            EndPoint="16.5,12.5" />
                          <LineGeometry
                            StartPoint="11.5,14.5"
                            EndPoint="16.5,14.5" />
                        </GeometryGroup>
                      </Path.Data>
                    </Path>
                  </RadioButton>
                  <RadioButton x:Name="ScrollViewButton"
                    Command="FlowDocumentReader.SwitchViewingModeCommand"
                    CommandParameter="Scroll"
                    Style="{StaticResource PUIFlowViewers_GrowShrinkOpacityRadioButton}"
                    GroupName="ViewingMode"
                    IsEnabled="{TemplateBinding FlowDocumentReader.IsScrollViewEnabled}"
                    ToolTip="Scroll Mode">
                    <Path
                      VerticalAlignment="Center"
                      Stroke="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}">
                      <Path.Data>
                        <GeometryGroup>
                          <RectangleGeometry
                            RadiusX="1"
                            RadiusY="1"
                            Rect=".5,.5 19,19" />
                          <RectangleGeometry
                            Rect="3.5,3.5 8, 13" />
                          <LineGeometry
                            StartPoint="3.5,4.5"
                            EndPoint="11.5,4.5" />
                          <LineGeometry
                            StartPoint="3.5,6.5"
                            EndPoint="11.5,6.5" />
                          <LineGeometry
                            StartPoint="3.5,8.5"
                            EndPoint="11.5,8.5" />
                          <LineGeometry
                            StartPoint="3.5,10.5"
                            EndPoint="11.5,10.5" />
                          <LineGeometry
                            StartPoint="3.5,12.5"
                            EndPoint="11.5,12.5" />
                          <LineGeometry
                            StartPoint="3.5,14.5"
                            EndPoint="11.5,14.5" />
                          <RectangleGeometry
                            Rect="13.5,3.5 3, 13" />
                          <RectangleGeometry
                            Rect="14.5,4.5 1, 3" />
                          <RectangleGeometry
                            Rect="14.5,12.5 1, 3" />
                        </GeometryGroup>
                      </Path.Data>
                    </Path>
                  </RadioButton>
                </StackPanel>
                <RepeatButton x:Name="DecreaseZoom"
                  Command="NavigationCommands.DecreaseZoom"
                  Grid.Column="1"
                  Width="{TemplateBinding Control.FontSize}"
                  Height="{TemplateBinding Control.FontSize}"
                  Foreground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}"
                  Style="{StaticResource PUIFlowViewers_ZoomOutButton}"
                  BorderBrush="{TemplateBinding Control.BorderBrush}"
                  IsEnabled="{TemplateBinding FlowDocumentReader.CanDecreaseZoom}"
                  ToolTip="Decrease Zoom">
                  <FrameworkElement.LayoutTransform>
                    <ScaleTransform ScaleX="2.2" ScaleY="2.2" />
                  </FrameworkElement.LayoutTransform>
                </RepeatButton>
                <Slider
                  Grid.Column="2"
                  Width="100"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  Style="{StaticResource PUIFlowViewers_Slider}"
                  FontSize="{TemplateBinding Control.FontSize}"
                  LargeChange="{TemplateBinding FlowDocumentReader.ZoomIncrement}"
                  Maximum="{TemplateBinding FlowDocumentReader.MaxZoom}"
                  Minimum="{TemplateBinding FlowDocumentReader.MinZoom}"
                  SmallChange="{TemplateBinding FlowDocumentReader.ZoomIncrement}"
                  TickFrequency="{TemplateBinding FlowDocumentReader.ZoomIncrement}"
                  Value="{Binding Path=Zoom, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                <RepeatButton x:Name="IncreaseZoom"
                  Command="NavigationCommands.IncreaseZoom"
                  Grid.Column="3"
                  Width="{TemplateBinding Control.FontSize}"
                  Height="{TemplateBinding Control.FontSize}"
                  Foreground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.CommandBarMenuGlyphBrushKey}}"
                  Style="{StaticResource PUIFlowViewers_ZoomInButton}"
                  BorderBrush="{TemplateBinding Control.BorderBrush}"
                  IsEnabled="{TemplateBinding FlowDocumentReader.CanIncreaseZoom}"
                  ToolTip="Increase Zoom">
                  <FrameworkElement.LayoutTransform>
                    <ScaleTransform ScaleX="2.2" ScaleY="2.2" />
                  </FrameworkElement.LayoutTransform>
                </RepeatButton>
              </Grid>
            </Grid>
            <Grid>
              <Border x:Name="PART_ContentHost"
                Margin="{TemplateBinding Control.Padding}"
                BorderBrush="{TemplateBinding Control.BorderBrush}"
                BorderThickness="{TemplateBinding Control.BorderThickness}"
                KeyboardNavigation.IsTabStop="false"
                KeyboardNavigation.TabIndex="1"
                KeyboardNavigation.TabNavigation="Local" />
            </Grid>
          </DockPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="FlowDocumentReader.ViewingMode" Value="Page">
              <Setter TargetName="PageViewButton" Property="ToggleButton.IsChecked" Value="True" />
            </Trigger>
            <Trigger Property="FlowDocumentReader.ViewingMode" Value="TwoPage">
              <Setter TargetName="TwoPageViewButton" Property="ToggleButton.IsChecked" Value="True" />
            </Trigger>
            <Trigger Property="FlowDocumentReader.ViewingMode" Value="Scroll">
              <Setter TargetName="ScrollViewButton" Property="ToggleButton.IsChecked" Value="True" />
              <Setter TargetName="PageCountAndButtons" Property="UIElement.Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="FlowDocumentReader.Document" Value="{x:Null}">
              <Setter TargetName="FindButton" Property="UIElement.IsEnabled" Value="false" />
            </Trigger>
            <Trigger Property="FlowDocumentReader.IsFindEnabled" Value="false">
              <Setter TargetName="FindButton" Property="UIElement.IsEnabled" Value="false" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
