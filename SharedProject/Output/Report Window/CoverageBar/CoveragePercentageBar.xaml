<UserControl x:Class="FineCodeCoverage.Output.CoveragePercentageBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FineCodeCoverage.Output"
             xmlns:wpf="clr-namespace:FineCodeCoverage.Wpf"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
              Margin="0"
             Padding="0"
			 ToolTip="{Binding ElementName=root, Path=CoverageTooltip}"
             x:Name="root">
	<Border RenderTransformOrigin="0.5,0.5" BorderBrush="{Binding CoverageBorderBrush,  ElementName=root}" BorderThickness="{Binding CoverageBorderThicknessActual, ElementName=root}">
        <Border.Resources>
            <wpf:SimpleLineBrushConverter x:Key="SimpleLineBrushConverter"/>
            <wpf:BoolRotateConverter x:Key="BoolRotateConverter"/>
        </Border.Resources>
        <Border.RenderTransform>
            <RotateTransform Angle="{Binding ElementName=root, Path=CoveredPercentageLeft, Converter={StaticResource BoolRotateConverter}, ConverterParameter=false}"/>
        </Border.RenderTransform>
        <ProgressBar x:Name="pb" Minimum="0" Maximum="1" BorderThickness="0"
					 Value="{Binding ElementName=root, Path=Percentage}"
					 >
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CoveragePercentageBarStyle,RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Static local:CoveragePercentageBarStyle.CoveredLine}">
                            <DataTrigger.Setters>
                                <Setter Property="Foreground" Value="{Binding CoveredBrush,RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource SimpleLineBrushConverter}}"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </DataTrigger.Setters>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CoveragePercentageBarStyle,RelativeSource={RelativeSource AncestorType=UserControl} }" Value="{x:Static local:CoveragePercentageBarStyle.Solid}">
                            <DataTrigger.Setters>
                                <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=CoveredBrush}"/>
                                <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=NotCoveredBrush}"/>
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>
	</Border>
	 </UserControl>