    <local:CoveragePercentageBarBase  x:Class="FineCodeCoverage.Output.CoveragePercentageBar"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:FineCodeCoverage.Output"
                 xmlns:wpf="clr-namespace:FineCodeCoverage.Wpf"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                  Margin="0"
                 Padding="0"
			     ToolTip="{Binding  RelativeSource={RelativeSource Self}, Path=CoverageTooltip}"
            >
    <ProgressBar Value="{Binding ProgressBarValue, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" x:Name="pb" Minimum="0" Maximum="1" BorderThickness="0" RenderTransformOrigin="0.5,0.5" 
        Foreground="{Binding ProgressBarForegroundBrush, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
        Background="{Binding ProgressBarBackgroundBrush, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <ProgressBar.RenderTransform>
            <RotateTransform Angle="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=RotationAngle}"/>
            </ProgressBar.RenderTransform>
    </ProgressBar>
</local:CoveragePercentageBarBase>