<UserControl
	x:Name="FCCOutputToolWindow"
	x:Class="FineCodeCoverage.Output.ReportToolWindowControl"
    x:ClassModifier="internal"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:tg="clr-namespace:TreeGrid;assembly=TreeGrid"
    xmlns:vsShell="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
    xmlns:output="clr-namespace:FineCodeCoverage.Output"
    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
    xmlns:wpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:effects="clr-namespace:System.Windows.Media.Extensions.Effects;assembly=WpfExtended"
	mc:Ignorable="d"
	d:DesignWidth="500"
	d:DesignHeight="300"
	>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <vsShell:VisibleIfEqualValueConverter x:Key="VisibleIfEqualValueConverter" VisibilityIfNotEqual="Hidden"/>
            <wpf:ResourceKeyConverter x:Key="ThemeResourceKeyConverter"/>
        </Grid.Resources>
        <ProgressBar Grid.Row="0" Height="2" Foreground="{DynamicResource ResourceKey=VsBrush.Highlight}" Visibility="{Binding CoverageRunning, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}" IsIndeterminate="true">
            <ProgressBar.Style>
                <Style TargetType="{x:Type ProgressBar}">
                    <Setter Property="FrameworkElement.MinWidth" Value="2"/>
                    <Setter Property="FrameworkElement.MinHeight" Value="2"/>
                    <Setter Property="FrameworkElement.UseLayoutRounding" Value="True"/>
                    <Setter Property="UIElement.SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ProgressBar}">
                                <Grid x:Name="TemplateRoot" SnapsToDevicePixels="True">
                                    <Border  BorderThickness="0"/>
                                    <Rectangle x:Name="PART_Track" />
                                    <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                        <Grid ClipToBounds="True">
                                            <Rectangle x:Name="Animation" Fill="{TemplateBinding Control.Foreground}"
                           RenderTransformOrigin="0.5,0.5">
                                                <UIElement.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform/>
                                                        <SkewTransform/>
                                                        <RotateTransform/>
                                                        <TranslateTransform/>
                                                    </TransformGroup>
                                                </UIElement.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                    </Decorator>
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Indeterminate">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Animation"
                                                   Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                        <EasingDoubleKeyFrame KeyTime="0" Value="0.25"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:1" Value="0.25"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:2" Value="0.25"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <PointAnimationUsingKeyFrames Storyboard.TargetName="Animation"
                                                  Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                                                        <EasingPointKeyFrame KeyTime="0" Value="-0.5,0.5"/>
                                                        <EasingPointKeyFrame KeyTime="0:0:1" Value="0.5,0.5"/>
                                                        <EasingPointKeyFrame KeyTime="0:0:2" Value="1.5,0.5"/>
                                                    </PointAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>
        <tg:TreeGridControl Grid.Row="1"
        TreeGridControlBackground="{DynamicResource {x:Static vsShell:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
        TreeViewBackground="{DynamicResource {x:Static vsShell:TreeViewColors.BackgroundBrushKey}}"
        HeaderGridLines="{Binding GridLinesBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderForeground="{Binding ForegroundBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderForegroundIsMouseOver="{Binding ForegroundIsMouseOverBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderForegroundIsPressed="{Binding ForegroundIsPressedBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderBackground="{Binding BackgroundBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderBackgroundIsMouseOver="{Binding BackgroundIsMouseOverBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        HeaderBackgroundIsPressed="{Binding BackgroundIsPressedBrushKey, Source={x:Static output:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
        ViewModel="{Binding}"
    >
            <tg:TreeGridControl.ItemTemplate>
                <DataTemplate>
                    <DataTemplate.Resources>
                        <output:PercentageConverter x:Key="PercentageConverter"/>
                    </DataTemplate.Resources>
                    <StackPanel>
                        <!-- cannot put margin in style due to the reparenting-->
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="Name" Text="{Binding Name}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="CoverableLines" Text="{Binding CoverableLines}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="CoveredLines" Text="{Binding CoveredLines}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="NotCoveredLines" Text="{Binding NotCoveredLines}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="PartialLines" Text="{Binding PartialLines}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="TotalBranches" Text="{Binding TotalBranches}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="CoveredBranches" Text="{Binding CoveredBranches}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="NotCoveredBranches" Text="{Binding NotCoveredBranches}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="NPathComplexity" Text="{Binding NPathComplexity}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="CyclomaticComplexity" Text="{Binding CyclomaticComplexity}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="CrapScore" Text="{Binding CrapScore}"/>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="LineCoveragePercent">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource PercentageConverter}">
                                    <Binding Path="CoverableLines" />
                                    <Binding Path="CoveredLines" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Margin="4,0,4,0" VerticalAlignment="Center" Tag="BranchCoveragePercent">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource PercentageConverter}">
                                    <Binding Path="TotalBranches" />
                                    <Binding Path="CoveredBranches" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Grid Tag="LineCoveragePercentBar" Margin="4,0,4,0">
                            <Grid.Resources>
                                <output:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
                                <output:BrushToSolidColorBrushConverter x:Key="BrushToSolidColorBrushConverter"/>
                                <vsShell:BrushToColorConverter x:Key="BrushToColorConverter"/>
                            </Grid.Resources>
                            <TextBlock Text="---"
                                    Visibility="{Binding CoverableLines,
                                    Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=false}" HorizontalAlignment="Center"/>
                            <output:CoveragePercentageBar Visibility="{Binding CoverableLines, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=true}" Margin="4,0,4,0" 
                                Coverable="{Binding CoverableLines}" 
                                Covered="{Binding CoveredLines}" 
                                Partial="{Binding PartialLines}"
                                UseSolidBrush="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=UseSolidBrush}"
                                NotCoveredColor="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=NotCoveredColor}"
                                CoveredColor="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredColor}"
                                CoveredPercentageIsLeft="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredPercentageIsLeft}"
                                DisplayParts="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=DisplayParts}"
                                HeightOrMultiplier="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=HeightOrMultiplier}"
                                ShowToolTip="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=ShowToolTip}"
                                >
                                <output:CoveragePercentageBar.Style>
                                    <Style TargetType="output:CoveragePercentageBar">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThemed, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="True">
                                                <Setter Property="ThemedBackgroundColor" Value="{Binding Background, Converter={StaticResource ResourceKey=BrushToColorConverter}}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsThemed, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="False">
                                                <Setter Property="ThemedBackgroundColor" Value="{x:Static media:Colors.Transparent}"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="True">
                                                <Setter Property="SingularPartBrush" Value="{Binding Foreground, Converter={StaticResource ResourceKey=BrushToSolidColorBrushConverter}}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="False">
                                                <Setter Property="SingularPartBrush" Value="{x:Static media:Brushes.Transparent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </output:CoveragePercentageBar.Style>
                            </output:CoveragePercentageBar>
                        </Grid>
                        <Grid Tag="BranchCoveragePercentBar" Margin="4,0,4,0">
                            <Grid.Resources>
                                <output:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
                                <output:BrushToSolidColorBrushConverter x:Key="BrushToSolidColorBrushConverter"/>
                                <vsShell:BrushToColorConverter x:Key="BrushToColorConverter"/>
                            </Grid.Resources>
                            <TextBlock Text="---"
            Visibility="{Binding TotalBranches,
            Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=false}" HorizontalAlignment="Center"/>
                            <output:CoveragePercentageBar Visibility="{Binding TotalBranches, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=true}" Margin="4,0,4,0" 
        Coverable="{Binding TotalBranches}" 
        Covered="{Binding CoveredBranches}" 
        UseSolidBrush="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=UseSolidBrush}"
        NotCoveredColor="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=NotCoveredColor}"
        CoveredColor="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredColor}"
        CoveredPercentageIsLeft="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredPercentageIsLeft}"
        DisplayParts="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=DisplayParts}"
        HeightOrMultiplier="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=HeightOrMultiplier}"
        ShowToolTip="{Binding Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=ShowToolTip}"
        >
                                <output:CoveragePercentageBar.Style>
                                    <Style TargetType="output:CoveragePercentageBar">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThemed, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="True">
                                                <Setter Property="ThemedBackgroundColor" Value="{Binding Background, Converter={StaticResource ResourceKey=BrushToColorConverter}}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsThemed, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="False">
                                                <Setter Property="ThemedBackgroundColor" Value="{x:Static media:Colors.Transparent}"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="True">
                                                <Setter Property="SingularPartBrush" Value="{Binding Foreground, Converter={StaticResource ResourceKey=BrushToSolidColorBrushConverter}}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static output:CoveragePercentageBarOptionsViewModelProvider.Instance}}" Value="False">
                                                <Setter Property="SingularPartBrush" Value="{x:Static media:Brushes.Transparent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </output:CoveragePercentageBar.Style>
                            </output:CoveragePercentageBar>
                        </Grid>
                    </StackPanel>
                </DataTemplate>
            </tg:TreeGridControl.ItemTemplate>
            <tg:TreeGridControl.HierarchicalDataTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <DockPanel>
                        <DockPanel.Resources>
                            <vsShell:VisibleIfEqualValueConverter x:Key="VisibleIfEqualValueConverter" VisibilityIfNotEqual="Collapsed"/>
                        </DockPanel.Resources>
                        <imaging:CrispImage
                            DockPanel.Dock="Left" VerticalAlignment="Center"
                             Margin="5 2 5 2"
                             Width="{Binding Source={x:Static output:IconsViewModelProvider.Instance}, Path=IconSize}"
                             Moniker="{Binding ImageMoniker}"
                             RenderOptions.BitmapScalingMode="HighQuality"
                             Visibility="{Binding Source={x:Static output:IconsViewModelProvider.Instance}, Path=ShowIcons, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}"
                        >
                            <!-- 
                Note that putting the effect in the trigger does not work with a dynamic resource.
                Hence added boolean to the effect to just return the original color when disabled
            -->
                            <imaging:CrispImage.Effect>
                                <effects:MonochromeAlphaSwap IsEnabled="{Binding Source={x:Static output:IconsViewModelProvider.Instance}, Path=Monochrome}"  FilterColor="{Binding Source={x:Static output:IconsViewModelProvider.Instance}, Path=MonochromeColor}"/>
                            </imaging:CrispImage.Effect>
                            <imaging:CrispImage.Style>
                                <Style TargetType="imaging:CrispImage">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Source={x:Static output:IconsViewModelProvider.Instance}, Path=Monochrome}" Value="False">
                                            <Setter Property="vsShell:ImageThemingUtilities.ImageBackgroundColor"  Value="{Binding ImageBackgroundColor, Source={x:Static output:ThemedTreeGridColours.Instance}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </imaging:CrispImage.Style>
                        </imaging:CrispImage>
                        <StackPanel VerticalAlignment="Center" Background="{Binding ImageBackgroundBrush, Source={x:Static output:ThemedTreeGridColours.Instance}}">
                            <StackPanel.RenderTransform>
                                <TranslateTransform X="{Binding Adjustment.TranslateX}"/>
                            </StackPanel.RenderTransform>
                            <Border Padding="0 2 0 2" Background="{Binding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding Adjustment.Width}"/>
                                    </Grid.ColumnDefinitions>
                                    <tg:TreeItemContentControl Content="{Binding}"
                    ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type tg:TreeGridControl}}, Path=ItemTemplate}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </DockPanel>


                </HierarchicalDataTemplate>
            </tg:TreeGridControl.HierarchicalDataTemplate>
        </tg:TreeGridControl>
    </Grid>
</UserControl>
