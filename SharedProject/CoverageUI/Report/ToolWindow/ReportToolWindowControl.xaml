<UserControl x:Name="FCCOutputToolWindow"
  x:Class="FineCodeCoverage.Output.ReportToolWindowControl"
  x:ClassModifier="internal"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:fccOutput="clr-namespace:FineCodeCoverage.Output"
  xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
  xmlns:vsImaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
  xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
  xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
  xmlns:treeGrid="clr-namespace:TreeGrid;assembly=TreeGrid"
  xmlns:wpfExtended="clr-namespace:System.Windows.Media.Extensions.Effects;assembly=WpfExtended"
  d:DesignHeight="300"
  d:DesignWidth="500"
  mc:Ignorable="d">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition
        Height="auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid.Resources>
      <vsPlatformUI:VisibleIfEqualValueConverter
        x:Key="VisibleIfEqualValueConverter"
        VisibilityIfNotEqual="Hidden" />
      <fccWpf:ResourceKeyConverter
        x:Key="ThemeResourceKeyConverter" />
    </Grid.Resources>
    <ProgressBar
      Grid.Row="0"
      Height="2"
      Foreground="{DynamicResource ResourceKey=VsBrush.Highlight}"
      IsIndeterminate="true"
      Visibility="{Binding CoverageRunning, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}">
      <ProgressBar.Style>
        <Style
          TargetType="{x:Type ProgressBar}">
          <Setter Property="FrameworkElement.MinWidth" Value="2" />
          <Setter Property="FrameworkElement.MinHeight" Value="2" />
          <Setter Property="FrameworkElement.UseLayoutRounding" Value="True" />
          <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
          <Setter Property="Control.Template">
            <Setter.Value>
              <ControlTemplate
                TargetType="{x:Type ProgressBar}">
                <Grid x:Name="TemplateRoot"
                  SnapsToDevicePixels="True">
                  <Border
                    BorderThickness="0" />
                  <Rectangle x:Name="PART_Track" />
                  <Decorator x:Name="PART_Indicator"
                    HorizontalAlignment="Left">
                    <Grid
                      ClipToBounds="True">
                      <Rectangle x:Name="Animation"
                        Fill="{TemplateBinding Control.Foreground}"
                        RenderTransformOrigin="0.5,0.5">
                        <UIElement.RenderTransform>
                          <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                          </TransformGroup>
                        </UIElement.RenderTransform>
                      </Rectangle>
                    </Grid>
                  </Decorator>
                  <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                      <VisualState x:Name="Indeterminate">
                        <Storyboard
                          RepeatBehavior="Forever">
                          <DoubleAnimationUsingKeyFrames
                            Storyboard.TargetName="Animation"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                            <EasingDoubleKeyFrame
                              KeyTime="0"
                              Value="0.25" />
                            <EasingDoubleKeyFrame
                              KeyTime="0:0:1"
                              Value="0.25" />
                            <EasingDoubleKeyFrame
                              KeyTime="0:0:2"
                              Value="0.25" />
                          </DoubleAnimationUsingKeyFrames>
                          <PointAnimationUsingKeyFrames
                            Storyboard.TargetName="Animation"
                            Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                            <EasingPointKeyFrame
                              KeyTime="0"
                              Value="-0.5,0.5" />
                            <EasingPointKeyFrame
                              KeyTime="0:0:1"
                              Value="0.5,0.5" />
                            <EasingPointKeyFrame
                              KeyTime="0:0:2"
                              Value="1.5,0.5" />
                          </PointAnimationUsingKeyFrames>
                        </Storyboard>
                      </VisualState>
                    </VisualStateGroup>
                  </VisualStateManager.VisualStateGroups>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ProgressBar.Style>
    </ProgressBar>
    <treeGrid:TreeGridControl
      Grid.Row="1"
      HeaderBackground="{Binding BackgroundBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderBackgroundIsMouseOver="{Binding BackgroundIsMouseOverBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderBackgroundIsPressed="{Binding BackgroundIsPressedBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderForeground="{Binding ForegroundBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderForegroundIsMouseOver="{Binding ForegroundIsMouseOverBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderForegroundIsPressed="{Binding ForegroundIsPressedBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      HeaderGridLines="{Binding GridLinesBrushKey, Source={x:Static fccOutput:ReportHeaderBrushesViewModelProvider.Instance}, Converter={StaticResource ResourceKey=ThemeResourceKeyConverter}}"
      TreeGridControlBackground="{DynamicResource {x:Static vsPlatformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
      TreeViewBackground="{DynamicResource {x:Static vsPlatformUI:TreeViewColors.BackgroundBrushKey}}"
      ViewModel="{Binding}">
      <treeGrid:TreeGridControl.ItemTemplate>
        <DataTemplate>
          <DataTemplate.Resources>
            <fccOutput:PercentageConverter
              x:Key="PercentageConverter" />
          </DataTemplate.Resources>
          <StackPanel>
            <!--  cannot put margin in style due to the reparenting  -->
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="Name"
              Text="{Binding Name}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="CoverableLines"
              Text="{Binding CoverableLines}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="CoveredLines"
              Text="{Binding CoveredLines}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="NotCoveredLines"
              Text="{Binding NotCoveredLines}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="PartialLines"
              Text="{Binding PartialLines}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="TotalBranches"
              Text="{Binding TotalBranches}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="CoveredBranches"
              Text="{Binding CoveredBranches}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="NotCoveredBranches"
              Text="{Binding NotCoveredBranches}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="NPathComplexity"
              Text="{Binding NPathComplexity}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="CyclomaticComplexity"
              Text="{Binding CyclomaticComplexity}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="CrapScore"
              Text="{Binding CrapScore}" />
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="LineCoveragePercent">
              <TextBlock.Text>
                <MultiBinding
                  Converter="{StaticResource PercentageConverter}">
                  <Binding
                    Path="CoverableLines" />
                  <Binding
                    Path="CoveredLines" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock
              Margin="4,0,4,0"
              VerticalAlignment="Center"
              Tag="BranchCoveragePercent">
              <TextBlock.Text>
                <MultiBinding
                  Converter="{StaticResource PercentageConverter}">
                  <Binding
                    Path="TotalBranches" />
                  <Binding
                    Path="CoveredBranches" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <Grid
              Margin="4,0,4,0"
              Tag="LineCoveragePercentBar">
              <Grid.Resources>
                <fccOutput:ZeroToVisibilityConverter
                  x:Key="ZeroToVisibilityConverter" />
                <fccOutput:BrushToSolidColorBrushConverter
                  x:Key="BrushToSolidColorBrushConverter" />
                <vsPlatformUI:BrushToColorConverter
                  x:Key="BrushToColorConverter" />
              </Grid.Resources>
              <TextBlock
                HorizontalAlignment="Center"
                Text="---"
                Visibility="{Binding CoverableLines, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=false}" />
              <fccOutput:CoveragePercentageBar
                Margin="4,0,4,0"
                Coverable="{Binding CoverableLines}"
                Covered="{Binding CoveredLines}"
                CoveredColor="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredColor}"
                CoveredPercentageIsLeft="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredPercentageIsLeft}"
                DisplayParts="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=DisplayParts}"
                HeightOrMultiplier="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=HeightOrMultiplier}"
                NotCoveredColor="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=NotCoveredColor}"
                Partial="{Binding PartialLines}"
                ShowToolTip="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=ShowToolTip}"
                UseSolidBrush="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=UseSolidBrush}"
                Visibility="{Binding CoverableLines, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=true}">
                <fccOutput:CoveragePercentageBar.Style>
                  <Style
                    TargetType="fccOutput:CoveragePercentageBar">
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding IsThemed, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="True">
                        <Setter Property="ThemedBackgroundColor" Value="{Binding Background, Converter={StaticResource ResourceKey=BrushToColorConverter}}" />
                      </DataTrigger>
                      <DataTrigger
                        Binding="{Binding IsThemed, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="False">
                        <Setter Property="ThemedBackgroundColor" Value="{x:Static media:Colors.Transparent}" />
                      </DataTrigger>

                      <DataTrigger
                        Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="True">
                        <Setter Property="SingularPartBrush" Value="{Binding Foreground, Converter={StaticResource ResourceKey=BrushToSolidColorBrushConverter}}" />
                      </DataTrigger>
                      <DataTrigger
                        Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="False">
                        <Setter Property="SingularPartBrush" Value="{x:Static media:Brushes.Transparent}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </fccOutput:CoveragePercentageBar.Style>
              </fccOutput:CoveragePercentageBar>
            </Grid>
            <Grid
              Margin="4,0,4,0"
              Tag="BranchCoveragePercentBar">
              <Grid.Resources>
                <fccOutput:ZeroToVisibilityConverter
                  x:Key="ZeroToVisibilityConverter" />
                <fccOutput:BrushToSolidColorBrushConverter
                  x:Key="BrushToSolidColorBrushConverter" />
                <vsPlatformUI:BrushToColorConverter
                  x:Key="BrushToColorConverter" />
              </Grid.Resources>
              <TextBlock
                HorizontalAlignment="Center"
                Text="---"
                Visibility="{Binding TotalBranches, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=false}" />
              <fccOutput:CoveragePercentageBar
                Margin="4,0,4,0"
                Coverable="{Binding TotalBranches}"
                Covered="{Binding CoveredBranches}"
                CoveredColor="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredColor}"
                CoveredPercentageIsLeft="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=CoveredPercentageIsLeft}"
                DisplayParts="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=DisplayParts}"
                HeightOrMultiplier="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=HeightOrMultiplier}"
                NotCoveredColor="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=NotCoveredColor}"
                ShowToolTip="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=ShowToolTip}"
                UseSolidBrush="{Binding Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}, Path=UseSolidBrush}"
                Visibility="{Binding TotalBranches, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=true}">
                <fccOutput:CoveragePercentageBar.Style>
                  <Style
                    TargetType="fccOutput:CoveragePercentageBar">
                    <Style.Triggers>
                      <DataTrigger
                        Binding="{Binding IsThemed, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="True">
                        <Setter Property="ThemedBackgroundColor" Value="{Binding Background, Converter={StaticResource ResourceKey=BrushToColorConverter}}" />
                      </DataTrigger>
                      <DataTrigger
                        Binding="{Binding IsThemed, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="False">
                        <Setter Property="ThemedBackgroundColor" Value="{x:Static media:Colors.Transparent}" />
                      </DataTrigger>

                      <DataTrigger
                        Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="True">
                        <Setter Property="SingularPartBrush" Value="{Binding Foreground, Converter={StaticResource ResourceKey=BrushToSolidColorBrushConverter}}" />
                      </DataTrigger>
                      <DataTrigger
                        Binding="{Binding UseContrastedThemeWhenSingularDisplay, Source={x:Static fccOutput:CoveragePercentageBarOptionsViewModelProvider.Instance}}"
                        Value="False">
                        <Setter Property="SingularPartBrush" Value="{x:Static media:Brushes.Transparent}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </fccOutput:CoveragePercentageBar.Style>
              </fccOutput:CoveragePercentageBar>
            </Grid>
          </StackPanel>
        </DataTemplate>
      </treeGrid:TreeGridControl.ItemTemplate>
      <treeGrid:TreeGridControl.HierarchicalDataTemplate>
        <HierarchicalDataTemplate
          ItemsSource="{Binding Children}">
          <DockPanel>
            <DockPanel.Resources>
              <vsPlatformUI:VisibleIfEqualValueConverter
                x:Key="VisibleIfEqualValueConverter"
                VisibilityIfNotEqual="Collapsed" />
            </DockPanel.Resources>
            <vsImaging:CrispImage
              DockPanel.Dock="Left"
              Width="{Binding Source={x:Static fccOutput:IconsViewModelProvider.Instance}, Path=IconSize}"
              Margin="5,2,5,2"
              VerticalAlignment="Center"
              Moniker="{Binding ImageMoniker}"
              RenderOptions.BitmapScalingMode="HighQuality"
              Visibility="{Binding Source={x:Static fccOutput:IconsViewModelProvider.Instance}, Path=ShowIcons, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}">
              <!--
                Note that putting the effect in the trigger does not work with a dynamic resource.
                Hence added boolean to the effect to just return the original color when disabled
              -->
              <vsImaging:CrispImage.Effect>
                <wpfExtended:MonochromeAlphaSwap
                  FilterColor="{Binding Source={x:Static fccOutput:IconsViewModelProvider.Instance}, Path=MonochromeColor}"
                  IsEnabled="{Binding Source={x:Static fccOutput:IconsViewModelProvider.Instance}, Path=Monochrome}" />
              </vsImaging:CrispImage.Effect>
              <vsImaging:CrispImage.Style>
                <Style
                  TargetType="vsImaging:CrispImage">
                  <Style.Triggers>
                    <DataTrigger
                      Binding="{Binding Source={x:Static fccOutput:IconsViewModelProvider.Instance}, Path=Monochrome}"
                      Value="False">
                      <Setter Property="vsPlatformUI:ImageThemingUtilities.ImageBackgroundColor" Value="{Binding ImageBackgroundColor, Source={x:Static fccOutput:ThemedTreeGridColours.Instance}}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </vsImaging:CrispImage.Style>
            </vsImaging:CrispImage>
            <StackPanel
              VerticalAlignment="Center"
              Background="{Binding ImageBackgroundBrush, Source={x:Static fccOutput:ThemedTreeGridColours.Instance}}">
              <StackPanel.RenderTransform>
                <TranslateTransform X="{Binding Adjustment.TranslateX}" />
              </StackPanel.RenderTransform>
              <Border
                Padding="0,2,0,2"
                Background="{Binding Background}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition
                      Width="{Binding Adjustment.Width}" />
                  </Grid.ColumnDefinitions>
                  <treeGrid:TreeItemContentControl
                    Content="{Binding}"
                    ContentTemplate="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type treeGrid:TreeGridControl}}, Path=ItemTemplate}" />
                </Grid>
              </Border>
            </StackPanel>
          </DockPanel>


        </HierarchicalDataTemplate>
      </treeGrid:TreeGridControl.HierarchicalDataTemplate>
    </treeGrid:TreeGridControl>
  </Grid>
</UserControl>
