<themedDialogs:ThemedDialogWindow
  x:Class="FineCodeCoverage.Output.ReportViewSelectorWindow"
  x:ClassModifier="internal"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:fccOutput="clr-namespace:FineCodeCoverage.Output"
  xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
  xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
  xmlns:vsShell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
  xmlns:themedDialogs="clr-namespace:VsThemedDialogs;assembly=VsThemedDialogs"
  xmlns:wpfGridExtensions="clr-namespace:WpfGridExtensions;assembly=WpfGridExtensions"
  Title="Report View Selector"
  SizeToContent="WidthAndHeight">
  <themedDialogs:ThemedDialogTitleOkCancel
    Title="Report View Selector">
    <StackPanel>
      <StackPanel.Resources>
        <vsPlatformUI:VisibleIfEqualValueConverter
          x:Key="VisibleIfEqualValueConverter"
          VisibilityIfNotEqual="Collapsed" />
        <Style
          TargetType="themedDialogs:ThemedSectionDivider">
          <Setter Property="Margin" Value="0,12,0,12" />
        </Style>
        <Style
          x:Key="comboBoxWithAutomationStyle"
          BasedOn="{StaticResource {x:Static vsShell:VsResourceKeys.ComboBoxItemStyleKey}}"
          TargetType="ComboBoxItem">
          <Setter Property="AutomationProperties.Name" Value="{Binding Display}" />
          <Setter Property="AutomationProperties.AutomationId" Value="{Binding Display}" />
        </Style>
      </StackPanel.Resources>
      <Grid
        wpfGridExtensions:PreviousRowWrapper.DefaultMarginBottom="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition
            Width="Auto" />
          <ColumnDefinition
            Width="12" />
          <ColumnDefinition
            Width="200" />
          <!--  Prevent window from expanding when long branch name  -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition />
          <wpfGridExtensions:PreviousRowWrapper
            RowHeight="Auto" />

          <RowDefinition />
          <wpfGridExtensions:PreviousRowWrapper
            RowHeight="Auto"
            Visible="{Binding ShowReportContentTypeCombo}" />

          <RowDefinition />
          <wpfGridExtensions:PreviousRowWrapper
            RowHeight="Auto"
            Visible="{Binding ShowRepositoriesCombo}" />

          <RowDefinition />
          <wpfGridExtensions:PreviousRowWrapper
            MarginBottom="0"
            RowHeight="Auto"
            Visible="{Binding ShowBranchesCombo}" />

        </Grid.RowDefinitions>
        <Label
          Grid.Row="0"
          Grid.Column="0"
          Content="Report Style:" />
        <ComboBox AutomationProperties.Name="ReportStyleCombo"
          Grid.Row="0"
          Grid.Column="2"
          DisplayMemberPath="Display"
          ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"
          ItemsSource="{Binding ReportStyles}"
          SelectedItem="{Binding SelectedReportStyle}" />

        <Label
          Grid.Row="2"
          Grid.Column="0"
          Content="Report Content:" />
        <ComboBox AutomationProperties.Name="ReportContentTypeCombo"
          Grid.Row="2"
          Grid.Column="2"
          DisplayMemberPath="Display"
          ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"
          ItemsSource="{Binding ReportContentTypes}"
          SelectedItem="{Binding SelectedReportContentType}" />

        <Label
          Grid.Row="4"
          Grid.Column="0"
          Content="Selected Repository:" />
        <ComboBox AutomationProperties.Name="RepositoryDisplayCombo"
          Grid.Row="4"
          Grid.Column="2"
          IsEnabled="{Binding GitCombosEnabled}"
          ItemsSource="{Binding RepositoryPaths}"
          SelectedItem="{Binding SelectedRepositoryPath}" />

        <Label
          Grid.Row="6"
          Grid.Column="0"
          Content="Branches:" />
        <ComboBox AutomationProperties.Name="BranchesCombo"
          Grid.Row="6"
          Grid.Column="2"
          DisplayMemberPath="Display"
          IsEnabled="{Binding GitCombosEnabled}"
          ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"
          ItemsSource="{Binding Branches}"
          SelectedItem="{Binding SelectedBranch}" />
      </Grid>
      <StackPanel
        Visibility="{Binding ShowNoRepositoriesMessage, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}">
        <themedDialogs:ThemedSectionDivider />
        <TextBlock
          HorizontalAlignment="Center"
          Text="{Binding NoRepositoriesMessage}" />
        <themedDialogs:ThemedSectionDivider />
      </StackPanel>
    </StackPanel>
  </themedDialogs:ThemedDialogTitleOkCancel>
</themedDialogs:ThemedDialogWindow>
