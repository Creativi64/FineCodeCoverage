<themedDialogs:ThemedDialogWindow 
	x:Class="FineCodeCoverage.Output.ReportViewSelectorWindow"
	x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:themedDialogs="clr-namespace:VsThemedDialogs;assembly=VsThemedDialogs"
    xmlns:output="clr-namespace:FineCodeCoverage.Output"
    xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:vsx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
    xmlns:theming="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
    xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
    xmlns:vsShell="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:wpfGridExtensions="clr-namespace:WpfGridExtensions;assembly=WpfGridExtensions"
	Title="Report View Selector"
	SizeToContent="WidthAndHeight"
    >
    <themedDialogs:ThemedDialogTitleOkCancel Title="Report View Selector">
        <StackPanel>
            <StackPanel.Resources>
                <vsShell:VisibleIfEqualValueConverter x:Key="VisibleIfEqualValueConverter" VisibilityIfNotEqual="Collapsed"/>
                <Style TargetType="themedDialogs:ThemedSectionDivider">
                    <Setter Property="Margin" Value="0,12,0,12"/>
                </Style>
                <Style x:Key="comboBoxWithAutomationStyle" BasedOn="{StaticResource {x:Static vsx:VsResourceKeys.ComboBoxItemStyleKey}}" TargetType="ComboBoxItem">
                    <Setter Property="AutomationProperties.Name" Value="{Binding Display}"/>
                    <Setter Property="AutomationProperties.AutomationId" Value="{Binding Display}"/>
                </Style>
            </StackPanel.Resources>
            <Grid wpfGridExtensions:PreviousRowWrapper.DefaultMarginBottom="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="200"/> <!-- Prevent window from expanding when long branch name-->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <wpfGridExtensions:PreviousRowWrapper RowHeight="Auto"/>

                    <RowDefinition/>
                    <wpfGridExtensions:PreviousRowWrapper RowHeight="Auto" Visible="{Binding ShowReportContentTypeCombo}"/>

                    <RowDefinition/>
                    <wpfGridExtensions:PreviousRowWrapper RowHeight="Auto" Visible="{Binding ShowRepositoriesCombo}"/>

                    <RowDefinition/>
                    <wpfGridExtensions:PreviousRowWrapper MarginBottom="0" RowHeight="Auto" Visible="{Binding ShowBranchesCombo}"/>

                </Grid.RowDefinitions>
                <Label Grid.Column="0" Grid.Row="0" Content="Report Style:"/>
                <ComboBox Grid.Column="2" Grid.Row="0" AutomationProperties.Name="ReportStyleCombo"
                DisplayMemberPath="Display"
                ItemsSource="{Binding ReportStyles}" SelectedItem="{Binding SelectedReportStyle}" ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"/>

                <Label Grid.Column="0" Grid.Row="2" Content="Report Content:"/>
                <ComboBox Grid.Column="2" Grid.Row="2" AutomationProperties.Name="ReportContentTypeCombo"
                DisplayMemberPath="Display"
                ItemsSource="{Binding ReportContentTypes}" SelectedItem="{Binding SelectedReportContentType}" ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"/>

                <Label Grid.Column="0" Grid.Row="4" Content="Selected Repository:"/>
                <ComboBox Grid.Column="2" Grid.Row="4" AutomationProperties.Name="RepositoryDisplayCombo" 
                IsEnabled="{Binding GitCombosEnabled}" 
                ItemsSource="{Binding RepositoryPaths}" SelectedItem="{Binding SelectedRepositoryPath}"/>

                <Label Grid.Column="0" Grid.Row="6" Content="Branches:"/>
                <ComboBox Grid.Column="2" Grid.Row="6" AutomationProperties.Name="BranchesCombo"
                IsEnabled="{Binding GitCombosEnabled}" DisplayMemberPath="Display"
                ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" ItemContainerStyle="{StaticResource comboBoxWithAutomationStyle}"/>
            </Grid>
            <StackPanel Visibility="{Binding ShowNoRepositoriesMessage, Converter={StaticResource VisibleIfEqualValueConverter}, ConverterParameter=true}">
                <themedDialogs:ThemedSectionDivider/>
                <TextBlock HorizontalAlignment="Center"  Text="{Binding NoRepositoriesMessage}" />
                <themedDialogs:ThemedSectionDivider/>
            </StackPanel>
            
        </StackPanel>
    </themedDialogs:ThemedDialogTitleOkCancel>
</themedDialogs:ThemedDialogWindow>
