<UserControl
    x:Class="FineCodeCoverage.Wpf.VsCrispImageButton2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d">
    <UserControl.Resources>
        <vsPlatformUI:BrushToColorConverter
            x:Key="BrushToColorConverter" />
    </UserControl.Resources>
    <Button
        Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
        Width="26"
        Height="23"
        MinWidth="26"
        Padding="0"
        fccWpf:DesignTimeImageThemingUtilities.ImageBackgroundColor="{Binding Background.Color, RelativeSource={RelativeSource Self}}"
        d:Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ButtonBrushKey}}">
        <Button.Content>
            <fccWpf:Crispy
                Moniker="{Binding ImageMoniker, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Button.Content>
    </Button>
</UserControl>
