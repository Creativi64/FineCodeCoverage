<UserControl x:Class="FineCodeCoverage.Wpf.VsCrispImageButton2" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
    >
    <Button x:Name="btn" Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Button.Content>
            <imaging:CrispImage Moniker="{Binding ImageMoniker, RelativeSource={RelativeSource AncestorType=UserControl}}" Width="16" Height="16" />
        </Button.Content>
    </Button>
</UserControl>
