<UserControl x:Class="FineCodeCoverage.Wpf.VsImageButton" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
    xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
    xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
 
    >
    <Button 
            vs:ImageThemingUtilities.ImageBackgroundColor="{DynamicResource {x:Static vs:CommonControlsColors.ButtonColorKey}}" 
            d:Background="{DynamicResource {x:Static vs:CommonControlsColors.ButtonBrushKey}}" 
            Padding="0" MinWidth="26" Width="26" Height="23"  
			Command="{Binding Command, RelativeSource={RelativeSource Self}}"
		    Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Image}"/>
</UserControl>
