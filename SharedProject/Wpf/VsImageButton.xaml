<UserControl
    x:Class="FineCodeCoverage.Wpf.VsImageButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:vsImaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
    xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d">
    <Button
        Command="{Binding Command, RelativeSource={RelativeSource Self}}"
        Width="26"
        Height="23"
        MinWidth="26"
        Padding="0"
        vsPlatformUI:ImageThemingUtilities.ImageBackgroundColor="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ButtonColorKey}}"
        d:Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ButtonBrushKey}}"
        Content="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Image}" />
</UserControl>
