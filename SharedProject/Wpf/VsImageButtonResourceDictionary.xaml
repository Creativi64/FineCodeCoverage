<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fccOutput="clr-namespace:FineCodeCoverage.Output"
    xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d">
    <Style
        TargetType="{x:Type fccWpf:VsImageButtonX}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Button
                        Command="{Binding Command, RelativeSource={RelativeSource TemplatedParent}}"
                        Width="26"
                        Height="23"
                        MinWidth="26"
                        Padding="0"
                        d:Background="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ButtonBrushKey}}"
                        d:Foreground="{DynamicResource {x:Static vsPlatformUI:CommonControlsColors.ButtonTextBrushKey}}"
                        Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
