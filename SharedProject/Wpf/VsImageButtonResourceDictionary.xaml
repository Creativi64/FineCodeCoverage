<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:output="clr-namespace:FineCodeCoverage.Output"
					xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
                    xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
                    xmlns:vsx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
                    xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
                    xmlns:theming="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
                    xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    mc:Ignorable="d"
                    >
    <Style TargetType="{x:Type fccWpf:VsImageButtonX}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Button d:Background="{DynamicResource {x:Static vs:CommonControlsColors.ButtonBrushKey}}"
                            d:Foreground="{DynamicResource {x:Static vs:CommonControlsColors.ButtonTextBrushKey}}"
                        Padding="0" MinWidth="26" Width="26" Height="23"
			            Command="{Binding Command, RelativeSource={RelativeSource TemplatedParent}}"
                        Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
	        	    />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
