<fccWpf:VsImageButtonX
    x:Class="FineCodeCoverage.Wpf.VsPathButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
    xmlns:vsPlatformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    mc:Ignorable="d">
    <fccWpf:VsImageButtonX.Resources>
        <Style
            TargetType="Path">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>
    </fccWpf:VsImageButtonX.Resources>
    <Canvas
        Width="16"
        Height="16"
        Background="Transparent">
        <ContentControl
            Content="{Binding Path, RelativeSource={RelativeSource AncestorType=fccWpf:VsImageButtonX}}" />
    </Canvas>
</fccWpf:VsImageButtonX>
