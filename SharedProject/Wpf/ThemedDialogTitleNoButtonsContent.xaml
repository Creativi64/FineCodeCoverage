<UserControl x:Class="FineCodeCoverage.Wpf.ThemedDialogTitleNoButtonsContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
             x:Name="_ThemedDialogTitleNoButtonsContent"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
	<StackPanel Margin="24,0,24,24">
		<fccWpf:ThemedDialogWindowTitle Title="{Binding Title, ElementName=_ThemedDialogTitleNoButtonsContent}"/>
		<ContentPresenter Margin="0,20,0,0" Content="{Binding Body, ElementName=_ThemedDialogTitleNoButtonsContent}"/>
	</StackPanel>
</UserControl>