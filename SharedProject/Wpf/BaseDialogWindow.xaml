<vs:DialogWindow x:Class="FineCodeCoverage.Wpf.BaseDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				 xmlns:fccWpf="clr-namespace:FineCodeCoverage.Wpf"
                 xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
                 xmlns:vsx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
                 fccWpf:Themes.UseVsTheme="True"
                 WindowStyle="None"
                 ResizeMode="CanResizeWithGrip"
                 SnapsToDevicePixels="True"
                 BorderThickness="1" 
                 BorderBrush="{DynamicResource {x:Static vs:ThemedDialogColors.WindowBorderBrushKey}}"
                 >
	<WindowChrome.WindowChrome>
		<WindowChrome  ResizeBorderThickness="5" GlassFrameThickness="0"/>
	</WindowChrome.WindowChrome>
	<Window.Resources>
		<Style TargetType="{x:Type ResizeGrip}">
			<Setter Property="FrameworkElement.MinWidth"
            Value="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
			<Setter Property="FrameworkElement.MinHeight"
            Value="{DynamicResource {x:Static SystemParameters.HorizontalScrollBarHeightKey}}"/>
			<Setter Property="Control.Background" Value="Transparent"/>
			<Setter Property="Control.Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type ResizeGrip}">
						<Grid SnapsToDevicePixels="true" Background="{TemplateBinding Control.Background}">
							<Path HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"
                  Data="M 9,0 L 11,0 11,11 0,11 0,9 3,9 3,6 6,6 6,3 9,3 Z">
								<Shape.Fill>
									<DrawingBrush Viewbox="0,0,3,3" Viewport="0,0,3,3" TileMode="Tile" ViewportUnits="Absolute"
                              ViewboxUnits="Absolute">
										<DrawingBrush.Drawing>
											<DrawingGroup>
												<DrawingGroup.Children>
													<GeometryDrawing Brush="{DynamicResource {x:Static vs:ThemedDialogColors.WindowPanelTextBrushKey}}" Geometry="M 0,0 L 2,0 2,2 0,2 Z"/>
												</DrawingGroup.Children>
											</DrawingGroup>
										</DrawingBrush.Drawing>
									</DrawingBrush>
								</Shape.Fill>
							</Path>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>
	<DockPanel Margin="24,0,20,20">
			<TextBlock DockPanel.Dock="Top" Text="Manage Columns" Margin="0,8,0,24"
					   Style="{StaticResource {x:Static vsx:VsResourceKeys.TextBlockEnvironment200PercentFontSizeStyleKey}}"
				Foreground="{DynamicResource {x:Static vs:ThemedDialogColors.HeaderTextBrushKey}}"/>

			<StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Margin="6,0" Command="{Binding OkCommand}">Ok</Button>
				<Button IsDefault="True" Command="{Binding CancelCommand}">Cancel</Button>
			</StackPanel>

			<ContentControl Content="{Binding}" />
		</DockPanel>
</vs:DialogWindow>
