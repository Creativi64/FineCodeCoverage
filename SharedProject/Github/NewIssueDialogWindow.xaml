<platform:DialogWindow  x:Class="FineCodeCoverage.Github.NewIssueDialogWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
                        xmlns:fccwpf="clr-namespace:FineCodeCoverage.Wpf"
                        mc:Ignorable="d"
                        d:DesignWidth="600"
						fccwpf:Themes.UseVsTheme="True"
                        Title="New Issue"
                        Width="600"
                        SizeToContent="Height"
						>
    <StackPanel Margin="8,8,8,0">
        <TextBlock>
            <Run Text="Visual Studio Version - "/>
            <Run Text="{Binding VsVersionString, Mode=OneWay}"/>
        </TextBlock>
        <TextBlock>
            <Run Text="FCC Version - "/>
            <Run Text="{Binding FccVersionString, Mode=OneWay}"/>
        </TextBlock>
        <Separator Margin="0,8,0,8"/>

        <TextBlock>Issue Title</TextBlock>
        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
        <Separator Margin="0,8,0,8"/>

        <TextBlock Margin="0,0,0,10">FCC Log</TextBlock>
        <TextBlock>
            <Run Text="If empty please run coverage again."/>
            <Hyperlink Command="{Binding RefreshFCCOutputCommand}">Refresh</Hyperlink>
        </TextBlock>
        <TextBlock>The log, below, will be copied to clipboard on submit.  Please paste into the issue in the browser.</TextBlock>
        <TextBlock>
            <Run Text="Alternatively,"/>
            <Hyperlink Command="{Binding MailToCommand}">mail privately</Hyperlink>
            <Run Text="after creating an issue.  Please add the issue number in the title"/>
        </TextBlock>
        <TextBox
            Margin="0,8,0,0"
            Height="340"
            TextWrapping="Wrap"
            AcceptsReturn="True"
            VerticalScrollBarVisibility="Auto"
            Text="{Binding FccOutput,UpdateSourceTrigger=PropertyChanged}"
        />
        <CheckBox Margin="0,8,0,0" IsChecked="{Binding HaveCheckedFCCIssues}">
            <TextBlock>
                <Run Text="Have checked"/>
                <Hyperlink Command="{Binding SearchIssuesCommand}">existing issues</Hyperlink>
            </TextBlock>
        </CheckBox>
        <CheckBox Margin="0,8,0,0" IsChecked="{Binding HaveReadReadme}">
            <TextBlock>
                <Run Text="Have read"/>
                <Hyperlink Command="{Binding OpenReadMeCommand}">readme</Hyperlink>
            </TextBlock>
        </CheckBox>

        <Button Margin="0,8,0,8" HorizontalAlignment="Left" Command="{Binding SubmitCommand}">Submit issue</Button>
    </StackPanel>
</platform:DialogWindow>
